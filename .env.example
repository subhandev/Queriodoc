# Copy this file to .env.local and fill in secret values.
# Run: npm run verify:setup

# ─── Clerk (required) — https://dashboard.clerk.com ───
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk routes (defaults match this app; change only if you customize paths)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/documents
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/documents
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/documents
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/documents

# ─── Supabase (required) — https://supabase.com/dashboard ───
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: only needed for direct browser Supabase access (app uses server APIs today)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── OpenAI (required) — https://platform.openai.com/api-keys ───
OPENAI_API_KEY=
